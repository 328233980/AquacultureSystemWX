<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aquaculture.mapper.HarvestMapper">

    <select id="findByCondition" resultType="com.aquaculture.entity.Harvest">
        SELECT * FROM harvest
        <where>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="pondId != null">
                AND pond_id = #{pondId}
            </if>
            <if test="startDate != null">
                AND harvest_date >= #{startDate}
            </if>
            <if test="endDate != null">
                AND harvest_date &lt;= #{endDate}
            </if>
        </where>
        ORDER BY harvest_date DESC
    </select>

</mapper>
