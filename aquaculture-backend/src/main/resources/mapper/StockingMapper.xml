<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aquaculture.mapper.StockingMapper">

    <select id="findByCondition" resultType="com.aquaculture.entity.StockingRecord">
        SELECT * FROM stocking_record
        <where>
            <if test="pondId != null">
                AND pond_id = #{pondId}
            </if>
            <if test="startDate != null">
                AND stocking_date >= #{startDate}
            </if>
            <if test="endDate != null">
                AND stocking_date &lt;= #{endDate}
            </if>
        </where>
        ORDER BY stocking_date DESC
    </select>

</mapper>
