<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aquaculture.mapper.FarmingLogMapper">

    <select id="findByCondition" resultType="com.aquaculture.entity.FarmingLog">
        SELECT * FROM farming_log
        <where>
            <if test="pondId != null">
                AND pond_id = #{pondId}
            </if>
            <if test="startDate != null">
                AND log_date >= #{startDate}
            </if>
            <if test="endDate != null">
                AND log_date &lt;= #{endDate}
            </if>
        </where>
        ORDER BY log_date DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countByCondition" resultType="int">
        SELECT COUNT(*) FROM farming_log
        <where>
            <if test="pondId != null">
                AND pond_id = #{pondId}
            </if>
            <if test="startDate != null">
                AND log_date >= #{startDate}
            </if>
            <if test="endDate != null">
                AND log_date &lt;= #{endDate}
            </if>
        </where>
    </select>

</mapper>
